# ~/.shellrc

# Editors
export EDITOR="nvim"
export NVIM_APPNAME="nvim-own"

# Node.js support
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"

# Aliases
alias ls="ls -A --color=auto"
alias ll="ls -la --color=auto"
alias nixc="sudoedit /etc/nixos/configuration.nix"
alias nixr="sudo nixos-rebuild switch"
alias png="ping www.google.com"
alias fd="fdfind"
alias df="cd ~/sources/dot-files/"
alias nvimc="cd ~/sources/dot-files/stow/nvim/.config/nvim-own/ && nvim ."
alias azl="az acr login --name acracaewkfsharedsrv"
alias lg="lazygit"
alias ld="lazydocker"

alias qws='git status'

qwl() {
  local amount="${1:-10}"
  local COLOR_AUTHOR="\e[36m"  # cyan
  local COLOR_RESET="\e[0m"

  git --no-pager log \
    -n "$amount" \
    --date=short \
    --pretty=format:'%h|%an|%s|%ad' \
  | while IFS="|" read -r hash author subject date; do
      # Truncate subject
      if [ ${#subject} -gt 60 ]; then
        subject="${subject:0:57}..."
      fi

      # Print with color for the author field
      printf "%-10s ${COLOR_AUTHOR}%-25s${COLOR_RESET} %-60s %s\n" \
        "$hash" "$author" "$subject" "$date"
    done
}

jnv() {
  local file
  local preview_cmd

  if command -v batcat >/dev/null 2>&1; then
    preview_cmd="batcat --style=numbers --color=always --line-range :500 {} 2>/dev/null"
  else
    preview_cmd="cat {} 2>/dev/null"
  fi

  if command -v fdfind >/dev/null 2>&1; then
    file=$(fdfind --type f --hidden --exclude .git | fzf --preview "$preview_cmd")
  elif command -v fd >/dev/null 2>&1; then
    file=$(fd --type f --hidden --exclude .git | fzf --preview "$preview_cmd")
  else
    file=$(find . -type f -not -path '/\.git/' 2>/dev/null | fzf --preview "$preview_cmd")
  fi

  if [[ -n "$file" ]]; then
    nvim "$file"
  fi
}

# Rust
. "$HOME/.cargo/env"
